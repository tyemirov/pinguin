DATABASE_PATH=/app/data/pinguin.db
GRPC_AUTH_TOKEN=change-me
LOG_LEVEL=DEBUG
MAX_RETRIES=5
RETRY_INTERVAL_SEC=2
CONNECTION_TIMEOUT_SEC=10
OPERATION_TIMEOUT_SEC=30

HTTP_LISTEN_ADDR=:8081
HTTP_ALLOWED_ORIGIN1=http://localhost:8080
HTTP_ALLOWED_ORIGIN2=
HTTP_ALLOWED_ORIGIN3=

# Hex-encoded 32-byte key. Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

TENANT_LOCAL_DOMAIN_PRIMARY=localhost
TENANT_LOCAL_DOMAIN_SECONDARY=127.0.0.1
TENANT_LOCAL_ADMIN_EMAIL_1=admin@localhost
TENANT_LOCAL_ADMIN_EMAIL_2=viewer@localhost
TENANT_LOCAL_SMTP_HOST=smtp.localhost
TENANT_LOCAL_SMTP_PORT=1025
TENANT_LOCAL_SMTP_USERNAME=smtp-user
TENANT_LOCAL_SMTP_PASSWORD=smtp-pass
TENANT_LOCAL_FROM_EMAIL=noreply@localhost

# Must match TAUTH_TENANT_JWT_SIGNING_KEY_PINGUIN in configs/.env.tauth.
TAUTH_SIGNING_KEY=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
TAUTH_COOKIE_NAME=app_session_pinguin
TAUTH_BASE_URL=http://localhost:8082
TAUTH_GOOGLE_CLIENT_ID=460317815414-f7ps2orvfcract2og605r2ghljbts4qv.apps.googleusercontent.com
TAUTH_TENANT_ID=pinguin

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

SMTP_SUBMISSION_ENABLED=false
SMTP_SUBMISSION_HOSTNAME=smtp.localhost
SMTP_SUBMISSION_LISTEN_ADDR=:587
SMTP_SUBMISSION_TLS_LISTEN_ADDR=:465
SMTP_SUBMISSION_TLS_CERT_PATH=/certs/smtp.crt
SMTP_SUBMISSION_TLS_KEY_PATH=/certs/smtp.key
SMTP_SUBMISSION_MAX_MESSAGE_BYTES=26214400
SMTP_SUBMISSION_MAX_RECIPIENTS=100
SMTP_SUBMISSION_ALLOW_INSECURE_AUTH=false
SMTP_SUBMISSION_SENDER_DOMAIN_1=localhost
SMTP_SUBMISSION_SENDER_DOMAIN_2=
SMTP_SUBMISSION_SENDER_DOMAIN_3=
SMTP_SUBMISSION_SENDER_DOMAIN_4=
SMTP_SUBMISSION_RELAY_HOST=smtp.localhost
SMTP_SUBMISSION_RELAY_PORT=1025
SMTP_SUBMISSION_RELAY_USERNAME=smtp-user
SMTP_SUBMISSION_RELAY_PASSWORD=smtp-pass
