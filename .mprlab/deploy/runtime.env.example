# Pinguin production environment for the MPR gateway.
# Copy to .mprlab/deploy/.env, replace secret placeholders, and keep mode 0600.

DATABASE_PATH=/app/data/pinguin.db
GRPC_AUTH_TOKEN=replace-with-pinguin-grpc-auth-token
LOG_LEVEL=INFO
MAX_RETRIES=5
RETRY_INTERVAL_SEC=2
CONNECTION_TIMEOUT_SEC=10
OPERATION_TIMEOUT_SEC=30
MASTER_ENCRYPTION_KEY=replace-with-hex-encoded-32-byte-key
TAUTH_SIGNING_KEY=replace-with-shared-tauth-signing-key
TAUTH_COOKIE_NAME=app_session_pinguin

HTTP_LISTEN_ADDR=:8080
HTTP_ALLOWED_ORIGIN1=https://poodlescanner.com
HTTP_ALLOWED_ORIGIN2=https://loopaware.mprlab.com
HTTP_ALLOWED_ORIGIN3=https://namesignal.mprlab.com

PINGUIN_TENANT_ID_PS=ps
PINGUIN_PS_DISPLAY_NAME=Poodle Scanner
PINGUIN_PS_SUPPORT_EMAIL=replace-with-support-email
PINGUIN_PS_ENABLED=true
PINGUIN_PS_DOMAIN_PRIMARY=poodlescanner.com
PINGUIN_PS_DOMAIN_SECONDARY=www.poodlescanner.com
PINGUIN_PS_ADMIN_EMAIL_1=replace-with-admin-email
PINGUIN_PS_ADMIN_EMAIL_2=replace-with-second-admin-email
PINGUIN_PS_SMTP_HOST=replace-with-smtp-host
PINGUIN_PS_SMTP_PORT=587
PINGUIN_PS_SMTP_USERNAME=replace-with-smtp-username
PINGUIN_PS_SMTP_PASSWORD=replace-with-smtp-password
PINGUIN_PS_FROM_EMAIL=noreply@poodlescanner.com
PINGUIN_PS_TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
PINGUIN_PS_TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
PINGUIN_PS_TWILIO_FROM_NUMBER=replace-with-twilio-from-number

PINGUIN_TENANT_ID_LA=loopaware
PINGUIN_LA_DISPLAY_NAME=LoopAware
PINGUIN_LA_SUPPORT_EMAIL=replace-with-support-email
PINGUIN_LA_ENABLED=true
PINGUIN_LA_DOMAIN_PRIMARY=loopaware.mprlab.com
PINGUIN_LA_ADMIN_EMAIL_1=replace-with-admin-email
PINGUIN_LA_ADMIN_EMAIL_2=replace-with-second-admin-email
PINGUIN_LA_SMTP_HOST=replace-with-smtp-host
PINGUIN_LA_SMTP_PORT=587
PINGUIN_LA_SMTP_USERNAME=replace-with-smtp-username
PINGUIN_LA_SMTP_PASSWORD=replace-with-smtp-password
PINGUIN_LA_FROM_EMAIL=noreply@loopaware.mprlab.com
PINGUIN_LA_TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
PINGUIN_LA_TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
PINGUIN_LA_TWILIO_FROM_NUMBER=replace-with-twilio-from-number

PINGUIN_TENANT_ID_NAMESIGNAL=namesignal
PINGUIN_NAMESIGNAL_DISPLAY_NAME=NameSignal
PINGUIN_NAMESIGNAL_SUPPORT_EMAIL=replace-with-support-email
PINGUIN_NAMESIGNAL_ENABLED=true
PINGUIN_NAMESIGNAL_DOMAIN_PRIMARY=namesignal.mprlab.com
PINGUIN_NAMESIGNAL_ADMIN_EMAIL_1=replace-with-admin-email
PINGUIN_NAMESIGNAL_ADMIN_EMAIL_2=replace-with-second-admin-email
PINGUIN_NAMESIGNAL_SMTP_HOST=replace-with-smtp-host
PINGUIN_NAMESIGNAL_SMTP_PORT=587
PINGUIN_NAMESIGNAL_SMTP_USERNAME=replace-with-smtp-username
PINGUIN_NAMESIGNAL_SMTP_PASSWORD=replace-with-smtp-password
PINGUIN_NAMESIGNAL_FROM_EMAIL=noreply@namesignal.mprlab.com
PINGUIN_NAMESIGNAL_TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
PINGUIN_NAMESIGNAL_TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
PINGUIN_NAMESIGNAL_TWILIO_FROM_NUMBER=replace-with-twilio-from-number

PINGUIN_TENANT_ID_SUMMERCAN=summercan
PINGUIN_SUMMERCAN_DISPLAY_NAME=SummerCan
PINGUIN_SUMMERCAN_SUPPORT_EMAIL=replace-with-support-email
PINGUIN_SUMMERCAN_ENABLED=true
PINGUIN_SUMMERCAN_DOMAIN_PRIMARY=summercan.mprlab.com
PINGUIN_SUMMERCAN_ADMIN_EMAIL_1=replace-with-admin-email
PINGUIN_SUMMERCAN_ADMIN_EMAIL_2=replace-with-second-admin-email
PINGUIN_SUMMERCAN_SMTP_HOST=replace-with-smtp-host
PINGUIN_SUMMERCAN_SMTP_PORT=587
PINGUIN_SUMMERCAN_SMTP_USERNAME=replace-with-smtp-username
PINGUIN_SUMMERCAN_SMTP_PASSWORD=replace-with-smtp-password
PINGUIN_SUMMERCAN_FROM_EMAIL=noreply@summercan.mprlab.com
PINGUIN_SUMMERCAN_TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
PINGUIN_SUMMERCAN_TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
PINGUIN_SUMMERCAN_TWILIO_FROM_NUMBER=replace-with-twilio-from-number

SMTP_SUBMISSION_HOSTNAME=smtp.poodlescanner.com
SMTP_SUBMISSION_LISTEN_ADDR=:587
SMTP_SUBMISSION_PUBLIC_PORT=465
SMTP_SUBMISSION_PUBLIC_SECURITY_MODE=ssl
SMTP_SUBMISSION_DELIVERY_MODE=upstream
SMTP_SUBMISSION_MAX_MESSAGE_BYTES=26214400
SMTP_SUBMISSION_MAX_RECIPIENTS=100
SMTP_SUBMISSION_ALLOW_INSECURE_AUTH=true
SMTP_SUBMISSION_RELAY_HOST=replace-with-smtp-relay-host
SMTP_SUBMISSION_RELAY_PORT=587
SMTP_SUBMISSION_RELAY_USERNAME=replace-with-smtp-relay-username
SMTP_SUBMISSION_RELAY_PASSWORD=replace-with-smtp-relay-password

SMTP_FORWARDING_ENABLED=true
SMTP_FORWARDING_HOSTNAME=mx.pinguin.mprlab.com
SMTP_FORWARDING_LISTEN_ADDR=:25
SMTP_FORWARDING_MAX_MESSAGE_BYTES=26214400
SMTP_FORWARDING_MAX_RECIPIENTS=100
SMTP_FORWARDING_RELAY_HOST=replace-with-smtp-relay-host
SMTP_FORWARDING_RELAY_PORT=587
SMTP_FORWARDING_RELAY_USERNAME=replace-with-smtp-relay-username
SMTP_FORWARDING_RELAY_PASSWORD=replace-with-smtp-relay-password
